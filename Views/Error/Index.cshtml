@model IEnumerable<SmartError.API.Models.ErrorLog>

<div class="container mt-4">
    <a href="/Error/Create"
       class="btn btn-primary btn-custom mb-3">
        + Add Error
    </a>

    <div class="search-panel">

        <form method="get">

            <div class="row g-2">

                <div class="col-md-3">
                    <input type="text"
                           name="searchTerm"
                           placeholder="Search Error..."
                           class="form-control" />
                </div>

                <div class="col-md-2">
                    <select name="category"
                            class="form-select">

                        <option value="">
                            All Categories
                        </option>

                        @foreach (var category in ViewBag.Categories)
                        {
                            <option value="@category.Name">
                                @category.Name
                            </option>
                        }

                    </select>
                </div>

                <div class="col-md-2">
                    <select name="severity"
                            class="form-select">

                        <option value="">
                            All Severities
                        </option>

                        @foreach (var severity in ViewBag.Severities)
                        {
                            <option value="@severity.Name">
                                @severity.Name
                            </option>
                        }

                    </select>
                </div>

                <div class="col-md-2">
                    <select name="status"
                            class="form-select">

                        <option value="">
                            All Status
                        </option>

                        <option value="Open">Open</option>
                        <option value="In Progress">In Progress</option>
                        <option value="Resolved">Resolved</option>

                    </select>
                </div>

                <div class="col-md-2">
                    <button type="submit"
                            class="btn btn-success w-100">
                        Search
                    </button>
                </div>

            </div>

        </form>

    </div>

<br />

    <table class="table table-hover align-middle custom-table">

        <thead>
            <tr>
                <th>Title</th>
                <th>Module</th>
                <th>Status</th>
                <th>Occurrences</th>
                <th>Category</th>
                <th>Severity</th>
                <th>Suggested Fix</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Title</td>
            <td>@item.ModuleName</td>
                    <td>

                        @if (item.Status == "Open")
                        {
                            <span class="badge bg-danger">Open</span>
                        }
                        else if (item.Status == "In Progress")
                        {
                            <span class="badge bg-warning text-dark">
                                In Progress
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-success">
                                Resolved
                            </span>
                        }

                    </td>
            <td>@item.OccurrenceCount</td>
            <td>@item.Category?.Name</td>
                    <td>

                        @if (item.Severity?.Name == "Critical")
                        {
                            <span class="badge bg-danger">
                                Critical
                            </span>
                        }
                        else if (item.Severity?.Name == "High")
                        {
                            <span class="badge bg-warning text-dark">
                                High
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-info">
                                @item.Severity?.Name
                            </span>
                        }

                    </td>
            <td>@item.SuggestedFix</td>

            <td>
               
                        <div class="d-flex gap-1">

                            <a href="/Error/Details/@item.Id"
                               class="btn btn-primary btn-sm">
                                View
                            </a>

                            <a href="/Error/Edit/@item.Id"
                               class="btn btn-warning btn-sm">
                                Edit
                            </a>

                            <a href="/Error/Delete/@item.Id"
                               class="btn btn-danger btn-sm"
                               onclick="return confirm('Delete this error?')">
                                Delete
                            </a>

                        </div>
            </td>
        </tr>
    }
        </tbody>

</table>
</div>