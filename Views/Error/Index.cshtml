@model IEnumerable<SmartError.API.Models.ErrorLog>

<h2>Error Logs</h2>

<p>
    <a href="/Error/Create">
        Add New Error
    </a>
</p>

<table border="1" cellpadding="10">

    <tr>
        <th>Title</th>
        <th>Module</th>
        <th>Status</th>
        <th>Occurrences</th>
        <th>Category</th>
        <th>Severity</th>
        <th>Suggested Fix</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Title</td>
            <td>@item.ModuleName</td>
            <td>@item.Status</td>
            <td>@item.OccurrenceCount</td>
            <td>@item.Category?.Name</td>
            <td>@item.Severity?.Name</td>
            <td>@item.SuggestedFix</td>
        </tr>
    }

</table>