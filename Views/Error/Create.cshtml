@model SmartError.API.DTOs.CreateErrorDto

<div class="container mt-4">

    <div class="form-card">

        <h2 class="page-title">
            🐞 Report New Error
        </h2>

        <form method="post">

            <div class="mb-3">
                <label class="form-label fw-bold">
                    Error Title
                </label>

                <input asp-for="Title"
                       class="form-control"
                       placeholder="Enter error title..." />
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">
                    Description
                </label>

                <textarea asp-for="Description"
                          class="form-control"
                          rows="4"
                          placeholder="Describe the issue...">
                </textarea>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">
                    Stack Trace
                </label>

                <textarea asp-for="StackTrace"
                          class="form-control"
                          rows="5"
                          placeholder="Paste stack trace here...">
                </textarea>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">
                    Module Name
                </label>

                <input asp-for="ModuleName"
                       class="form-control"
                       placeholder="Example: User Service" />
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold">
                    Status
                </label>

                <select asp-for="Status"
                        class="form-select">

                    <option>Open</option>
                    <option>In Progress</option>
                    <option>Resolved</option>

                </select>
            </div>

            <div class="d-flex gap-2">

                <button type="submit"
                        class="btn btn-success">
                    Save Error
                </button>

                <a href="/Error/Index"
                   class="btn btn-secondary">
                    Cancel
                </a>

            </div>

        </form>

    </div>

</div>