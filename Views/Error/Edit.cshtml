@model SmartError.API.Models.ErrorLog

<div class="container mt-4">

    <div class="form-card">

        <h2 class="page-title">
            ✏️ Edit Error
        </h2>

        <form method="post">

            <input asp-for="Id" type="hidden" />

            <div class="mb-3">
                <label class="form-label fw-bold">
                    Error Title
                </label>

                <input asp-for="Title"
                       class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">
                    Status
                </label>

                <select asp-for="Status"
                        class="form-select">

                    <option>Open</option>
                    <option>In Progress</option>
                    <option>Resolved</option>

                </select>

            </div>

            <div class="mb-4">

                <label class="form-label fw-bold">
                    Suggested Fix
                </label>

                <textarea asp-for="SuggestedFix"
                          class="form-control"
                          rows="5">
                </textarea>

            </div>

            <div class="d-flex gap-2">

                <button type="submit"
                        class="btn btn-warning">
                    Update Error
                </button>

                <a href="/Error/Index"
                   class="btn btn-secondary">
                    Cancel
                </a>

            </div>

        </form>

    </div>

</div>