@model SmartError.API.ViewModels.DashboardViewModel

<div class="container mt-4">

    <h1 class="page-title text-center mb-4">
        📊 Smart Error Detective Dashboard
    </h1>

    <p class="text-center text-muted mb-5">
        Monitor, Analyze and Track Application Errors
    </p>

    <div class="row">

        <div class="col-md-6 mb-4">
            <div class="card bg-primary text-white card-shadow">
                <div class="card-body text-center d-flex flex-column justify-content-center">
                    <h5>Total Errors</h5>
                    <div class="stat-number">
                        @Model.TotalErrors
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card bg-danger text-white card-shadow">
                <div class="card-body text-center d-flex flex-column justify-content-center">
                    <h5>Critical Errors</h5>
                    <div class="stat-number">
                        @Model.CriticalErrors
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card bg-warning card-shadow">
                <div class="card-body text-center d-flex flex-column justify-content-center">
                    <h5>High Errors</h5>
                    <div class="stat-number">
                        @Model.HighErrors
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card bg-success text-white card-shadow">
                <div class="card-body text-center d-flex flex-column justify-content-center">
                    <h5>Duplicate Errors</h5>
                    <div class="stat-number">
                        @Model.DuplicateErrors
                    </div>
                </div>
            </div>
        </div>

    </div>

</div>
<div class="row mt-5">

    <div class="col-md-6">

        <div class="form-card">

            <h4 class="mb-3">
                Error Severity Distribution
            </h4>

            <canvas id="severityChart"></canvas>

        </div>

    </div>

    <div class="col-md-6">

        <div class="form-card">

            <h4 class="mb-3">
                Error Category Distribution
            </h4>

            <canvas id="categoryChart"></canvas>

        </div>

    </div>

</div>


@section Scripts {

    <script>

        var severityLabels =
        @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SeverityData.Keys));

        var severityValues =
        @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SeverityData.Values));

        new Chart(
        document.getElementById('severityChart'),
        {
            type: 'pie',

            data: {
                labels: severityLabels,

                datasets: [{
                    data: severityValues
                }]
            }
        });

        var categoryLabels =
        @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CategoryData.Keys));

        var categoryValues =
        @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CategoryData.Values));

        new Chart(
        document.getElementById('categoryChart'),
        {
            type: 'bar',

            data: {
                labels: categoryLabels,

                datasets: [{
                    label: 'Errors',
                    data: categoryValues
                }]
            }
        });

    </script>

}